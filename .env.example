# Backend

COMPOSE_PROJECT_NAME=mvp_qcp
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=5173

ENV=dev
APP_NAME=QCP MVP API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./data/qcp.db
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TOKEN_EXPIRE_HOURS=24
RQ_JOB_TIMEOUT_SECONDS=90
TASK_MAX_RETRIES=2
TASK_RETRY_BACKOFF_SECONDS=1,3
QUEUE_MAX_DEPTH=200
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_CLEANUP_BATCH_SIZE=200

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# For Docker Compose, REDIS_URL is overridden as redis://redis:6379/0

QIBO_EXEC_TIMEOUT_SECONDS=60
EXECUTION_BACKEND=docker
EXECUTION_IMAGE=qcp-backend-dev:latest
EXECUTION_RUNNER_MODULE=app.services.execution.runner
EXECUTION_READ_ONLY_ROOTFS=true
EXECUTION_NETWORK_DISABLED=true
EXECUTION_MEM_LIMIT_MB=256
EXECUTION_CPU_LIMIT=0.5
EXECUTION_PIDS_LIMIT=64
EXECUTION_TMPFS_SIZE_MB=64
