# Backend

ENV=dev
APP_NAME=QCP MVP API
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://qcp:qcp_dev_password@127.0.0.1:5432/qcp
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TOKEN_EXPIRE_HOURS=24
TASK_QUEUE_NAME=qcp-default
CIRCUIT_TASK_QUEUE_NAME=qcp-circuit
TASK_JOB_TIMEOUT_SECONDS=90
TASK_MAX_RETRIES=2
TASK_RETRY_BACKOFF_SECONDS=1,3
QUEUE_MAX_DEPTH=200
CIRCUIT_EXEC_BACKEND=numpy
CIRCUIT_EXEC_POOL_SIZE=1
CIRCUIT_EXEC_TIMEOUT_SECONDS=60
CIRCUIT_EXEC_HEARTBEAT_SECONDS=10
CIRCUIT_EXEC_HEARTBEAT_TTL_SECONDS=30
CIRCUIT_EXEC_HEARTBEAT_KEY=qcp:circuit:heartbeat
WORKER_ROLE=default
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_CLEANUP_BATCH_SIZE=200

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:8000

# For Docker Compose, REDIS_URL is overridden as redis://redis:6379/0

QIBO_EXEC_TIMEOUT_SECONDS=60
EXECUTION_BACKEND=docker
EXECUTION_SERVICE_URL=
EXECUTION_SERVICE_TIMEOUT_SECONDS=75
EXECUTION_IMAGE=qcp-backend-dev:latest
EXECUTION_RUNNER_MODULE=app.services.execution.runner
DOCKER_SOCKET_PATH=/var/run/docker.sock
EXECUTION_READ_ONLY_ROOTFS=true
EXECUTION_NETWORK_DISABLED=true
EXECUTION_MEM_LIMIT_MB=256
EXECUTION_CPU_LIMIT=0.5
EXECUTION_PIDS_LIMIT=64
EXECUTION_TMPFS_SIZE_MB=64

# Legacy one-time migration source
SQLITE_SOURCE_DATABASE_URL=sqlite:///./backend/data/qcp.db
