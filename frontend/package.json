{
  "name": "qcp-mvp-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:no-mock && npm run test:encoding && vitest run --config vitest.config.mjs",
    "test:no-mock": "node tests-node/no-mock-tests.mjs",
    "test:encoding": "node tests-node/encoding-guard.mjs",
    "test:node": "node tests-node/run-tests.mjs",
    "test:e2e": "playwright test --config playwright.config.ts",
    "generate:contracts": "python ../scripts/generate_openapi_contracts.py"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "katex": "^0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^2.1.5"
  }
}
