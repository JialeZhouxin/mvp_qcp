# CN deployment / restricted-network example

# Use internal registries as the first choice.
POSTGRES_IMAGE=registry.example.com/mirror/postgres:16-alpine
REDIS_IMAGE=registry.example.com/mirror/redis:7-alpine
BACKEND_IMAGE=registry.example.com/qcp/qcp-backend:2026.04.02
FRONTEND_IMAGE=registry.example.com/qcp/qcp-frontend:2026.04.02

# Build-time mirrors (for dev and CI build nodes).
APT_MIRROR_URL=https://mirrors.aliyun.com/debian
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
NPM_REGISTRY=https://registry.npmmirror.com
NPM_FETCH_RETRIES=5
NPM_FETCH_RETRY_FACTOR=2
NPM_FETCH_RETRY_MINTIMEOUT=20000
NPM_FETCH_RETRY_MAXTIMEOUT=120000

# Runtime app settings
ENV=prod
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql+psycopg://qcp:<replace-me>@postgres:5432/qcp
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_NAME=qcp-default
CIRCUIT_TASK_QUEUE_NAME=qcp-circuit
HYBRID_TASK_QUEUE_NAME=qcp-hybrid
EXECUTION_BACKEND=remote
EXECUTION_SERVICE_URL=http://execution-service:8010
EXECUTION_SERVICE_TIMEOUT_SECONDS=75
DOCKER_SOCKET_PATH=/var/run/docker.sock
